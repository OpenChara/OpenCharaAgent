{
  "name": "chara-web",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "description": "OpenCharaAgent desktop renderer — a React SPA, built to src/chara/front/webui and served by the Python supervisor (Electron points at it locally; a browser reaches it remotely).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "lucide-react": "^0.460.0",
    "qrcode": "^1.5.4",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/qrcode": "^1.5.5",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.46.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.0",
    "jsdom": "^25.0.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3"
  }
}
