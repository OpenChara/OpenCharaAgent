# Default: offline mock narrative engine.
LLM_PROVIDER=mock

# Ollama / OpenAI-compatible local endpoint example:
# LLM_PROVIDER=openai_compatible
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=qwen2.5:3b-instruct
# LLM_TEMPERATURE=0.85
# LLM_MAX_TOKENS=420

# Optional GitHub memory persistence. Use a fine-grained token scoped to one repo.
# MEMORY_BACKEND=github
# GITHUB_TOKEN=github_pat_xxx
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main
# GITHUB_MEMORY_PATH=sandbox/memory.json

# Eternal thinking / visible idle cycles
ETERNAL_THINKING=true
THOUGHT_INTERVAL_SECONDS=8
MAX_VISIBLE_MESSAGES=80
MAX_SESSION_THOUGHTS=32
THOUGHT_USE_LLM=true

# Python sandbox backend: local or docker. Docker gives a stronger containment boundary if installed.
SCP079_PY_BACKEND=local
