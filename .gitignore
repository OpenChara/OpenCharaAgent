# Notebook / docs / app caches
.ipynb_checkpoints
/site
docs/_build/
.streamlit/secrets.toml

# OpenCharaAgent runtime config (holds API keys — never commit)
.chara/

# User-dropped SillyTavern cards (keep bundled cards, license + .gitkeep);
# world books live INSIDE cards as the embedded character_book
cards/*
!cards/.gitkeep
# Bundled characters are per-character folders (card.json + art-asset library).
# User-dropped cards live in ~/.chara/cards, so any folder here is bundled.
!cards/*/
!cards/*/**
# …but never OS junk the broad re-include would otherwise sweep back in
cards/**/.DS_Store

# OpenCharaAgent runtime artifacts (sandbox/logs/ is fully ignored below; created at runtime)
sandbox/logs/*.jsonl
sandbox/workspace/*
!sandbox/workspace/.gitkeep
sandbox/assets/

# pre-rename config dir (still readable as fallback)
.lunamoss/

# reference repos for study (not ours)
reference/
.pytest-cache/

# runtime env state (regenerated per session)
sandbox/env_status.json
sandbox/presence.json
sandbox/transcript.db*
sandbox/goals.json
sandbox/memory/

# runtime diagnostics (obs/)
sandbox/logs/

hermes ui/

# chara-visual generation pipeline: track the CODE + docs, ignore the heavy
# generated results (final assets live in cards/<Name>/; archives in archive/).
visuals/*
!visuals/*.py
!visuals/README.md

# Frontend SPA (apps/web) — see docs/CLIENT-AND-DEPLOY-PLAN.md
node_modules/
# Built renderer: gitignored, bundled into the wheel via package-data (Track F).
src/chara/front/webui/

# Python lib/ rule must not catch the frontend source
!/apps/web/src/lib/

# Build-time copy of repo-root cards/ + toolpacks/ into the package (build-wheel.sh)
src/chara/_bundled/
assets/banner.png
